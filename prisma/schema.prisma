generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ AUTH ============
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin") // admin | staff
  createdAt DateTime @default(now())

  sessions POSSession[]
}

// ============ PRODUCT CATEGORY ============
model ProductCategory {
  id       String    @id @default(cuid())
  name     String
  color    String    @default("#6F4E37")
  sequence Int       @default(0)

  products Product[]
}

// ============ PRODUCT ============
model Product {
  id          String   @id @default(cuid())
  name        String
  categoryId  String
  price       Float    @default(0)
  unit        String   @default("Unit") // Unit | KG | Liter
  tax         Float    @default(5)
  description String   @db.Text
  image       String?

  category    ProductCategory @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  orderLines  OrderLine[]
}

// ============ PRODUCT VARIANT ============
model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  attribute  String
  value      String
  unit       String  @default("Unit")
  extraPrice Float   @default(0)

  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ============ PAYMENT METHOD CONFIG ============
model PaymentMethodConfig {
  id      String  @id @default(cuid())
  cash    Boolean @default(true)
  digital Boolean @default(true)
  upi     Boolean @default(false)
  upiId           String  @default("")
  kitchenPassword String  @default("")
}

// ============ FLOOR ============
model Floor {
  id          String  @id @default(cuid())
  name        String
  posTerminal String  @default("SipSync")

  tables      FloorTable[]
}

// ============ TABLE ============
model FloorTable {
  id      String  @id @default(cuid())
  number  Int
  seats   Int     @default(4)
  active  Boolean @default(true)
  floorId String

  floor   Floor   @relation(fields: [floorId], references: [id], onDelete: Cascade)

  @@map("floor_table")
}

// ============ CUSTOMER ============
model Customer {
  id         String  @id @default(cuid())
  name       String
  email      String  @default("")
  phone      String  @default("")
  street1    String  @default("")
  street2    String  @default("")
  city       String  @default("")
  state      String  @default("")
  country    String  @default("")
  totalSales Float   @default(0)

  orders     Order[]
}

// ============ POS SESSION ============
model POSSession {
  id             String    @id @default(cuid())
  name           String
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
  openingAmount  Float     @default(0)
  closingAmount  Float     @default(0)
  responsibleId  String
  isOpen         Boolean   @default(true)

  responsible    User      @relation(fields: [responsibleId], references: [id])
  orders         Order[]
}

// ============ ORDER ============
model Order {
  id            String   @id @default(cuid())
  orderNo       String
  sessionId     String?
  date          DateTime @default(now())
  tableId       String   @default("")
  tableNumber   Int      @default(0)
  total         Float    @default(0)
  tax           Float    @default(0)
  finalTotal    Float    @default(0)
  status        String   @default("draft") // draft | paid
  customerId    String?
  customerName  String   @default("")
  kitchenStatus String   @default("to_cook") // to_cook | preparing | completed

  session       POSSession?   @relation(fields: [sessionId], references: [id])
  customer      Customer?     @relation(fields: [customerId], references: [id])
  lines         OrderLine[]
  payments      OrderPayment[]
}

// ============ ORDER LINE ============
model OrderLine {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Int     @default(1)
  price       Float   @default(0)
  tax         Float   @default(0)
  unit        String  @default("Unit")
  subtotal    Float   @default(0)
  notes       String  @default("")

  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])
}

// ============ ORDER PAYMENT ============
model OrderPayment {
  id      String   @id @default(cuid())
  orderId String
  method  String   // cash | digital | upi
  amount  Float    @default(0)
  date    DateTime @default(now())

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
